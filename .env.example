###############################################################################
# GODMODE — Environment Variables Example
# Copy this file to .env and fill in every value before running docker compose.
#
# SECURITY: Never commit .env to version control.
# Generate strong secrets with: openssl rand -hex 32
###############################################################################

# =============================================================================
# LIBRECHAT CORE — Required
# =============================================================================

# Node environment
NODE_ENV=production

# Public URL of the app (used for CORS, OAuth callbacks, etc.)
# On Windows with Docker Desktop: http://localhost:3080
PUBLIC_URL=http://localhost:3080

# LibreChat encryption keys (MUST be unique strong secrets)
# Generate: openssl rand -hex 32
CREDS_KEY=replace_with_64_hex_chars_openssl_rand_hex_32
CREDS_IV=replace_with_32_hex_chars_openssl_rand_hex_16

# JWT secrets (MUST be unique strong secrets)
# Generate: openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars_jwt_secret
JWT_REFRESH_SECRET=replace_with_64_hex_chars_jwt_refresh_secret

# =============================================================================
# AI MODEL PROVIDERS — Required
# =============================================================================

# Anthropic (primary: Claude Opus + Sonnet)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (fallback / vision: GPT-4o)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# DATABASE — MongoDB
# =============================================================================

# MongoDB connection URI (internal Docker network)
MONGO_URI=mongodb://mongodb:27017/LibreChat

# =============================================================================
# SEARCH — Meilisearch
# =============================================================================

# Meilisearch master key (generate a strong random string)
# Generate: openssl rand -hex 32
MEILI_MASTER_KEY=replace_with_64_hex_chars_meili_master_key

# Enable conversation search
SEARCH=true

# =============================================================================
# VECTOR STORE — Qdrant
# =============================================================================

# Qdrant URL (internal Docker network)
QDRANT_URL=http://qdrant:6333

# Optional: Qdrant API key (set if you enable Qdrant authentication)
QDRANT_API_KEY=

# =============================================================================
# RAG API — Document retrieval
# =============================================================================

# RAG API port
RAG_PORT=8000

# Embeddings provider: openai | huggingface | ollama
EMBEDDINGS_PROVIDER=openai

# Embeddings model
EMBEDDINGS_MODEL=text-embedding-3-small

# =============================================================================
# MEMORY — Mem0 / OpenMemory MCP
# =============================================================================

# Mem0 Cloud API key (optional — for hybrid cloud/local memory)
# Get key: https://app.mem0.ai/settings/api-keys
# Leave blank to use fully local/self-hosted Qdrant-backed memory only
MEM0_API_KEY=

# Name of the Qdrant collection used for memory storage
MEM0_COLLECTION_NAME=godmode_memory

# =============================================================================
# VISION BRIDGE — Webcam relay service
# =============================================================================

# Default vision provider: anthropic | openai
VISION_DEFAULT_PROVIDER=anthropic

# Default vision model
VISION_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Max number of recent webcam frames to include per analysis request
VISION_MAX_FRAMES=4

# =============================================================================
# REGISTRATION / AUTH
# =============================================================================

# Allow new user registration (true = open, false = invite only)
ALLOW_REGISTRATION=true

# Allow social/OAuth login
ALLOW_SOCIAL_LOGIN=false

# =============================================================================
# MEMORY FEATURE FLAG
# =============================================================================

# Enable LibreChat native memory feature
MEMORY_ENABLED=true

# =============================================================================
# OPTIONAL: EMAIL (for password reset)
# =============================================================================

# SMTP config — leave blank to disable email
EMAIL_SERVICE=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=GODMODE
